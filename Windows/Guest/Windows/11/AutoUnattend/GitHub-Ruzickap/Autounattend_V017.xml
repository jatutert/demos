                    <!-- Windows 10 and 11 Education           NW6C2-QMPVW-D7KKK-3GKT6-VCFB2 -->
                    <!-- Windows 10 and 11 Enterprise          NPPR9-FWDCX-D2C8J-H872K-2YT43 -->
                    <Key>YNMGQ-8RYV3-4PGQ3-C8XTP-7CFBY</Key>
