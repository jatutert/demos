                <Model>Virtual Machine</Model>
            </OEMInformation>
            <OEMName>Saxion</OEMName>
            <ComputerName>W11-EDU-S-LAB01</ComputerName>
            <TimeZone>W. Europe Standard Time</TimeZone>
            <DisableAutoDaylightTimeSet>false</DisableAutoDaylightTimeSet>
