                <!-- Step 2                                                  -->
                <!-- OpenSSH Server                                          -->
                <!-- Download Script from Github                             -->
                <SynchronousCommand wcm:action="add">
                    <CommandLine>cmd.exe /c powershell -Command "Invoke-WebRequest -URI https://raw.githubusercontent.com/jatutert/Windows-Config/refs/heads/main/PS-Windows-VM-OOBE/Windows-Remote-SSH/VM-OOBE-Config-SSH-V003.ps1 -OutFile %userprofile%\Downloads\VM-OOBE-Config-SSH-V003.ps1"</CommandLine>
