#   Image laag 0
#   Alpine Linux
FROM alpine:latest

#   Image Laag 1
#   Shell

#   Image laag 2
#   Package Manager update 
RUN apk update 

#   Image laag 3
#   Application Installation 
RUN apk add py3-pip py3-flask wget -q

#   Image laag 4
#   Maak directories
RUN mkdir -p /usr/src/app/templates 

#   Image laag 5 
#   Python Script
RUN wget -q --no-check-certificate -O /usr/src/app/app.py https://raw.githubusercontent.com/jatutert/demos/main/Docker/Dockerfiles/FLASK/app.py

#   Image laag 6
#   Index HTML
RUN wget -q --no-check-certificate -O /usr/src/app/templates/index.html https://raw.githubusercontent.com/jatutert/demos/main/Docker/Dockerfiles/FLASK/index.html

#   Image laag 7
#   tell the port number the container should expose
EXPOSE 5000

#   Image laag 8
#   Start applicatie bij iedere start van deze image als container 
CMD ["python", "/usr/src/app/app.py"]

# That is all folks ! 